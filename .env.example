# Zello Work credentials (loaded from credentials.env)
ZELLO_NETWORK=your-network-name
ZELLO_BOT_USER=bot-username       # defaults to ZELLO_ADMIN_USER if not set
ZELLO_BOT_PASS=bot-password       # defaults to ZELLO_ADMIN_PASS if not set

# Channels to join (comma-separated)
ZELLO_BRIDGE_CHANNELS=dispatch,field-ops

# OpenClaw gateway
GATEWAY_TOKEN=your-gateway-token
OPENCLAW_GATEWAY=http://127.0.0.1:18789
OPENCLAW_AGENT=haldeman           # which agent handles voice
OPENCLAW_SESSION_USER=zello-voice # session user ID for continuity

# STT method: "faster-whisper" (local) or "zello-transcription" (use Zello's built-in)
STT_METHOD=faster-whisper
WHISPER_MODEL=base.en
