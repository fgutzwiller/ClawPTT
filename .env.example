# ═══════════════════════════════════════════════════════════════
# PinchPTT — Zello Voice Bridge
#
# PinchPTT handles voice I/O only: STT, TTS, and Zello transport.
# All intelligence (model, tools, search, persona) is configured
# in the agent that sits behind the LLM endpoint.
# ═══════════════════════════════════════════════════════════════

# ─── Zello Work ────────────────────────────────────────────────
ZELLO_NETWORK=your-network-name
ZELLO_BOT_USER=bot-username
ZELLO_BOT_PASS=bot-password
ZELLO_BRIDGE_CHANNELS=channel-name   # comma-separated

# ─── LLM Endpoint ─────────────────────────────────────────────
# "openclaw" → OpenClaw gateway (agent handles model/tools/search)
# "local"    → any OpenAI-compatible endpoint (vLLM, Ollama, LiteLLM)
LLM_BACKEND=openclaw

# OpenClaw gateway
GATEWAY_TOKEN=your-gateway-token
OPENCLAW_GATEWAY=http://127.0.0.1:18789
OPENCLAW_AGENT=main

# Local endpoint (used when LLM_BACKEND=local)
# LOCAL_LLM_URL=http://127.0.0.1:8888/v1/chat/completions
# LOCAL_LLM_API_KEY=your-key
# LOCAL_LLM_MODEL=Qwen/Qwen3-Coder-Next-FP8
# LOCAL_LLM_MAX_TOKENS=512
# LOCAL_LLM_TEMPERATURE=0.7
# AGENT_SYSTEM_PROMPT="Your system prompt here"

# ─── STT ───────────────────────────────────────────────────────
WHISPER_MODEL=base.en                # base.en, small.en, medium.en, large-v3
# STT_METHOD=faster-whisper          # or "zello-transcription"

# ─── TTS ───────────────────────────────────────────────────────
TTS_VOICE=en_US-lessac-high          # Piper voice model name
# Models: https://github.com/k2-fsa/sherpa-onnx/releases/tag/tts-models
# Examples: en_US-lessac-high, en_US-hfc_male-medium, en_GB-alan-medium
