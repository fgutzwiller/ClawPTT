# ═══════════════════════════════════════════════════════════════
# PinchPTT Configuration
# ═══════════════════════════════════════════════════════════════

# ─── Zello Work ────────────────────────────────────────────────
ZELLO_NETWORK=your-network-name
ZELLO_BOT_USER=bot-username          # defaults to ZELLO_ADMIN_USER
ZELLO_BOT_PASS=bot-password          # defaults to ZELLO_ADMIN_PASS
ZELLO_BRIDGE_CHANNELS=dispatch       # comma-separated channel names

# ─── LLM Backend ──────────────────────────────────────────────
# "openclaw" → route through OpenClaw gateway (agent handles model, tools, search)
# "local"    → direct OpenAI-compatible API call (vLLM, Ollama, LiteLLM, etc)
LLM_BACKEND=local

# ─── OpenClaw Gateway (for "openclaw" backend) ────────────────
GATEWAY_TOKEN=your-gateway-token
OPENCLAW_GATEWAY=http://127.0.0.1:18789
OPENCLAW_AGENT=main                  # agent ID to route voice to

# ─── Local LLM (for "local" backend) ──────────────────────────
LOCAL_LLM_URL=http://127.0.0.1:8888/v1/chat/completions
LOCAL_LLM_API_KEY=your-api-key
LOCAL_LLM_MODEL=your-model-id
LOCAL_LLM_MAX_TOKENS=512
LOCAL_LLM_TEMPERATURE=0.7

# ─── Agent Persona (for "local" backend) ──────────────────────
# AGENT_SYSTEM_PROMPT=               # override the default system prompt

# ─── STT (Speech-to-Text) ─────────────────────────────────────
STT_METHOD=faster-whisper             # or "zello-transcription"
WHISPER_MODEL=base.en                 # base.en, small.en, medium.en, large-v3

# ─── TTS (Text-to-Speech) ─────────────────────────────────────
TTS_VOICE=en_US-hfc_male-medium       # Piper voice model name
# Download models to ~/.openclaw/tools/sherpa-onnx-tts/models/
# Available: en_US-lessac-high, en_US-hfc_male-medium, en_GB-alan-medium, etc.
